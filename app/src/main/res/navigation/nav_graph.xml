<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/calendarFragment">

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.example.rednotebook.ui.calendar.CalendarFragment"
        android:label="Calendar">
        <action android:id="@+id/action_calendar_to_editor" app:destination="@id/editorFragment" />
    </fragment>

    <fragment
        android:id="@+id/listFragment"
        android:name="com.example.rednotebook.ui.list.ListFragment"
        android:label="Entries">
        <action android:id="@+id/action_list_to_editor" app:destination="@id/editorFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.rednotebook.ui.search.SearchFragment"
        android:label="Search">
        <action android:id="@+id/action_search_to_editor" app:destination="@id/editorFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.rednotebook.ui.settings.SettingsFragment"
        android:label="Settings" />

    <fragment
        android:id="@+id/editorFragment"
        android:name="com.example.rednotebook.ui.editor.EditorFragment"
        android:label="Entry">
        <argument android:name="year"  app:argType="integer" android:defaultValue="0" />
        <argument android:name="month" app:argType="integer" android:defaultValue="0" />
        <argument android:name="day"   app:argType="integer" android:defaultValue="0" />
    </fragment>

</navigation>
